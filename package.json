{
  "name": "evinka-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "test:flow": "node scripts/test_supabase_flow.mjs",
    "check:flow": "node --check scripts/test_supabase_flow.mjs",
    "chatbot:cli": "node scripts/run_chatbot_cli.mjs",
    "check:chatbot": "node --check src/chatbotEngine.mjs && node --check scripts/run_chatbot_cli.mjs && node --check src/receiptOcr.mjs",
    "meta:webhook": "node src/metaWebhookServer.mjs",
    "check:meta": "node --check src/whatsappMeta.mjs && node --check src/metaWebhookServer.mjs && node --check src/receiptOcr.mjs",
    "test:ocr": "node scripts/test_receipt_ocr.mjs",
    "cotizador:web": "node apps/cotizador-web/server.mjs",
    "overview:web": "cd apps/overview-app && npm run build:data && npm run serve",
    "evinka:apk": "cd apps/evinka-suite && JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64 /opt/flutter/bin/flutter build apk --release",
    "bioplasticoeduca:android:build": "cd apps/bioplasticoeduca-web && npm run android:build:debug",
    "mapco:google-validate": "node scripts/validate_mapco_google_places.mjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.99",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "file-type": "^22.0.1",
    "heic-convert": "^2.1.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  }
}
